

generator client {
  provider = "prisma-client"
  output = "./generated"
	engineType = "client"
	runtime = "bun"
}

datasource db {
  provider = "postgresql"
  
}

//defining models

model User{
  id             String            @id   @default(ulid())
  username       String 
  provider       AuthProvider        
  email          String               @unique   
  conversations  Conversations[]            
  }


model Conversations{
  id            String           @id     @default(uuid())
  title         String?
  slug          String
  userId        String
  messages      Message[]
  user          User          @relation(fields: [userId],references: [id])
}

model Message {
  id                Int           @id   @default(autoincrement())
  content           String
  role              MessageRole
  conversationId    String
  createdAt         DateTime
  conversations     Conversations     @relation(fields: [conversationId],references: [id])
}

enum AuthProvider {
  github
  Google
}

enum MessageRole {
  User
  Assistant
}